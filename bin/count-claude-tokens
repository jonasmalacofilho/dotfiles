#!/usr/bin/env python3

import json
import os
import sys
import urllib.request

MODELS = {
    "Sonnet 4.6": "claude-sonnet-4-6",
    "Opus 4.7":   "claude-opus-4-7",
}


def count_tokens(api_key, model_id, text):
    payload = json.dumps({
        "model": model_id,
        "system": text,
        "messages": [{"role": "user", "content": "."}],
    }).encode()
    req = urllib.request.Request(
        "https://api.anthropic.com/v1/messages/count_tokens",
        data=payload,
        headers={
            "x-api-key": api_key,
            "anthropic-version": "2023-06-01",
            "anthropic-beta": "token-counting-2024-11-01",
            "content-type": "application/json",
        },
    )
    try:
        with urllib.request.urlopen(req) as resp:
            return json.loads(resp.read())["input_tokens"]
    except urllib.error.HTTPError as e:
        body = json.loads(e.read())
        msg = body.get("error", {}).get("message", e.reason)
        print(f"error: {msg}", file=sys.stderr)
        sys.exit(1)


def main():
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help"):
        print(f"Usage: {os.path.basename(sys.argv[0])} <file> [file ...]")
        sys.exit(0 if len(sys.argv) > 1 else 1)

    api_key = os.environ.get("ANTHROPIC_API_KEY", "")
    if not api_key:
        print("error: ANTHROPIC_API_KEY not set", file=sys.stderr)
        sys.exit(1)

    files = sys.argv[1:]
    results = []

    for path in files:
        try:
            with open(path) as f:
                text = f.read()
        except OSError as e:
            print(f"error: {e}", file=sys.stderr)
            sys.exit(1)
        counts = {label: count_tokens(api_key, model_id, text) for label, model_id in MODELS.items()}
        results.append((path, counts))

    col_file = max(len("File"), max(len(p) for p, _ in results))
    col_w = {label: max(len(label), 6) for label in MODELS}

    header = f"{'File':<{col_file}}  " + "  ".join(f"{label:>{col_w[label]}}" for label in MODELS)
    print(header)
    print("-" * len(header))
    for path, counts in results:
        print(f"{path:<{col_file}}  " + "  ".join(f"{counts[label]:>{col_w[label]}}" for label in MODELS))


if __name__ == "__main__":
    main()
