export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"

export EDITOR=nvim
export VISUAL=nvim

# Claude Code privacy settings.
#
# IMPORTANT: the most important setting is to forbid the use of my data for training, which can
# be be done via <https://claude.ai/settings/data-privacy-controls> or with `/privacy-settings`.
#
# Don't simply set CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1 to preserve the remove control
# capability.
#
# References:
# - https://code.claude.com/docs/en/data-usage#telemetry-services
# - https://code.claude.com/docs/en/env-vars
# - https://code.claude.com/docs/en/remote-control#%E2%80%9Dremote-control-is-not-yet-enabled-for-your-account%E2%80%9D
export DISABLE_ERROR_REPORTING=1

export RIPGREP_CONFIG_PATH="$XDG_CONFIG_HOME/ripgreprc"
