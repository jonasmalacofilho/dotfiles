[user]
	name = Jonas Malaco
	email = jonas@protocubo.io
	signingkey = 06af7ad0

[alias]
	difft = !GIT_EXTERNAL_DIFF='difft --display=side-by-side' git diff "$@"
	fpush = push --force-with-lease --force-if-includes
	head = !git --no-pager log --abbrev=12 --oneline --format='%h' -1
	klog = log --format='%C(auto)%h%C(reset) ("%s")'
	main = !git switch $(git rev-parse --abbrev-ref origin/HEAD | sed 's|origin/||')
	pulls = fetch origin "+refs/pull/*:refs/origin/pull/*"
	slog = log --format='%C(auto)%h%d %s %C(dim)[%aN, %ar]%C(reset)' --graph
	sloga = log --format='%C(auto)%h%d %s %C(dim)[%aN, %ar]%C(reset)' --graph --all
	upulls = fetch upstream "+refs/pull/*:refs/upstream/pull/*"

[core]
	abbrev = 12
	excludesfile = ~/.gitignore.global
	pager = less

[branch]
	sort = -committerdate

[commit]
	verbose = true

[diff]
	algorithm = histogram
	colorMoved = plain
	mnemonicPrefix = true
	renames = true
	submodule = log

[fetch]
	all = true
	prune = true

# For patch-based workflows.
[format]
	signOff = true

[help]
	autocorrect = prompt

[init]
	defaultBranch = main

[log]
	date = iso

[merge]
	conflictstyle = zdiff3

[push]
	autoSetupRemote = true
	followTags = true

[rebase]
	autoSquash = true
	updateRefs = true

# Reuse recorded resolutions.
[rerere]
	autoupdate = true
	enabled = true

[tag]
	sort = -version:refname

[url "git@github.com:"]
	insteadOf = "gh:"

[url "git@gitlab.com:"]
	insteadOf = "gl:"

# For patch-based workflows.
[sendemail]
	annotate = true
	confirm = always
	smtpencryption = tls
	smtpserver = smtp.gmail.com
	smtpserverport = 587
	smtpuser = jonas@protocubo.io
	suppressfrom = false

